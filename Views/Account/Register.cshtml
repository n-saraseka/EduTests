@model EduTests.Models.RegisterViewModel

<!DOCTYPE html>

<html>
<head>
    <title>Register</title>
</head>
<body>
<h2>Регистрация</h2>

@if (!User.Identity.IsAuthenticated)
{
    <form asp-action="Register" method="post" id="register-form">
        @Html.AntiForgeryToken()
    
        <div class="form-group">
            <label asp-for="Login" class="required-field"></label>
            <input asp-for="Login" class="form-control" />
        </div>
    
        <div class="form-group">
            <label asp-for="Username" class="required-field"></label>
            <input asp-for="Username" class="form-control" />
        </div>
    
        <div class="form-group">
            <label asp-for="Password" class="required-field"></label>
            <input asp-for="Password" class="form-control" type="password"/>
        </div>
    
        <div class="form-group">
            <label asp-for="ConfirmPassword" class="required-field"></label>
            <input asp-for="ConfirmPassword" class="form-control" type="password"/>
        </div>
    
        <button type="submit" class="btn btn-primary">Зарегистрироваться</button>
    </form>
    
    <div id="error-text"></div>
    
    <div id="reg-account-help">Уже имеете аккаунт? <a asp-action="Login">Войдите здесь</a>.</div>
}
else
{
    <div>Вы уже вошли в аккаунт. <a asp-route="logout">Выход</a></div>
}

<script type="module" src="http://localhost:5173/@@vite/client"></script>
<script type="module" src="http://localhost:5173/src/regScripts.jsx"></script>
</body>
</html>